<%#
  VIEW / ESTADO / LACUNAS / ENDPOINTS
  Tela: Dados Salvos / Historico de checkpoints.
  Visual: dados-salvos.png [A1].
  View solicitada: src/views/dadosSalvos/dadosSalvos.ejs [A1].
  Estado de entrega: C1 - view SSR conectada por checkpointController.renderSavedByTeam.
  Rota SSR:
    - GET /view/competitions/:id/teams/:teamId/checkpoints/saved [A1][B1][C1].
  Endpoints de dados permitidos pela Secao 7:
    - GET /competitions/:id/checkpoints [A1][B1: Checkpoint[] confirmado em controller/service/model/repository].
  Decisoes:
    - Integracao SSR sem fetch, pois nao ha componente interativo nesta tela [D1].
    - Estado preenchido + vazio para array de checkpoints [D1].
    - Sem validacao client-side, pois nao ha formulario [D1].
    - Dados externos exibidos somente com tags EJS escapadas [D1].
    - CSS usa apenas variaveis existentes em public/css/variables.css [A1][D1].
    - Menu Equipes destacado por CSS nesta tela, sem JS e sem reload [D1].
    - Metodo exibido por inferencia do identifier: MANUAL- => Manual, OCR- => OCR, OCR-EDITED- / CORRIGIDO- => Corrigido [A2][B2][D1].
    - Cards de resumo calculados no controller a partir de checkpoints reais [A1][B1][D1].
    - Historico limitado a equipe da URL via runner.id_team === :teamId [A1][B1][D1].
  Campos esperados em checkpoints:
    - id, identifier, distance_km, pace, time, created_at, runner.name, runner.id_team [B1].
%>

<link rel="stylesheet" href="/css/dadosSalvos.css">

<%
  const checkpoints = Array.isArray(locals.checkpoints) ? locals.checkpoints : [];
  const summary = locals.summary || {};
  const formatDistance = (value) => {
    const normalizedValue = String(value ?? 0).replace(',', '.').replace(/[^\d.-]/g, '');
    const numericValue = Number(normalizedValue);
    const safeValue = Number.isFinite(numericValue) ? numericValue : 0;
    return safeValue.toLocaleString('pt-BR', {
      minimumFractionDigits: safeValue % 1 === 0 ? 0 : 1,
      maximumFractionDigits: 1
    });
  };
  const formatMethod = (identifier) => {
    if (!identifier) return 'Nao informado';
    const id = String(identifier).toUpperCase();
    if (id.startsWith('MANUAL-')) return 'Manual';
    if (id.startsWith('OCR-EDITED-') || id.startsWith('CORRIGIDO-') || id.startsWith('CORREÇÃO-') || id.startsWith('REVISADO-')) return 'Corrigido';
    if (id.startsWith('OCR-')) return 'OCR';
    return 'Desconhecido';
  };
  const totalDistance = summary.totalDistanceKm ?? checkpoints.reduce((sum, checkpoint) => {
    return sum + Number(checkpoint.distance_km || 0);
  }, 0);
  const averagePace = summary.averagePace || '0:00';
  const averageTime = summary.averageTime || '0h 00m';
%>

<main class="saved-data-page" aria-labelledby="saved-data-title">
  <header class="saved-data-header">
    <p class="saved-data-breadcrumb">Equipes &gt; Equipe &gt; Operacional &gt; Registros</p>
    <h1 id="saved-data-title">Dados Salvos</h1>
  </header>

  <% if (locals.error) { %>
    <div class="saved-data-alert" role="alert">
      <%= error %>
    </div>
  <% } %>

  <section class="saved-data-metrics" aria-label="Resumo dos checkpoints">
    <article class="saved-data-metric">
      <h2>Distância acumulada</h2>
      <strong><%= formatDistance(totalDistance) %> km</strong>
      <p>Soma de todos os checkpoints</p>
    </article>

    <article class="saved-data-metric">
      <h2>Pace médio</h2>
      <strong><%= averagePace %> /km</strong>
      <p>Recalculando a cada refresh</p>
    </article>

    <article class="saved-data-metric">
      <h2>Tempo médio por atleta</h2>
      <strong><%= averageTime %></strong>
      <p>Soma dos turnos</p>
    </article>
  </section>

  <section class="saved-data-history" aria-labelledby="checkpoint-history-title">
    <h2 id="checkpoint-history-title">Histórico de checkpoints</h2>

    <% if (checkpoints.length === 0) { %>
      <div class="saved-data-empty">
        <p>Nenhum checkpoint salvo ainda.</p>
      </div>
    <% } else { %>
      <div class="saved-data-table-wrap">
        <table class="saved-data-table">
          <thead>
            <tr>
              <th scope="col">#</th>
              <th scope="col">Horário</th>
              <th scope="col">Atleta</th>
              <th scope="col">Distância</th>
              <th scope="col">Pace</th>
              <th scope="col">Tempo</th>
              <th scope="col">Responsável</th>
              <th scope="col">Método</th>
              <th scope="col">Última atualização</th>
            </tr>
          </thead>
          <tbody>
            <% checkpoints.forEach((checkpoint, index) => { %>
              <tr data-id="<%= checkpoint.id %>">
                <td><%= String(index + 1).padStart(2, '0') %></td>
                <td>
                  <%= checkpoint.created_at
                    ? new Date(checkpoint.created_at).toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' })
                    : '--:--:--' %>
                </td>
                <td><%= checkpoint.runner?.name || 'Atleta nao informado' %></td>
                <td><%= formatDistance(checkpoint.distance_km) %> km</td>
                <td><%= checkpoint.pace || '--' %></td>
                <td><%= checkpoint.time || '--' %></td>
                <td><%= checkpoint.admin?.name || 'Admin nao informado' %></td>
                <td><%= formatMethod(checkpoint.identifier) %></td>
                <td><%= checkpoint.created_at ? new Date(checkpoint.created_at).toLocaleString('pt-BR') : 'Data nao informada' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</main>

<div id="checkpoint-modal" aria-hidden="true" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; z-index:9999; align-items:center; justify-content:center; background:rgba(0,0,0,0.75);">
  <div role="dialog" aria-modal="true" aria-labelledby="modal-title"
       style="position:relative; z-index:1; background:#fff; border-radius:15px; width:480px; max-width:calc(100vw - 32px); overflow:hidden; box-shadow:0 8px 40px rgba(0,0,0,0.25); font-family:'Montserrat',sans-serif;">

    <!-- Header azul -->
    <header style="background:#0f0069; padding:20px 24px; display:flex; align-items:center; justify-content:space-between;">
      <h3 id="modal-title" style="font-size:18px; font-weight:800; color:#fff; margin:0;">Editar Checkpoint</h3>
      <button type="button" id="modal-close" aria-label="Fechar"
              style="background:transparent; border:none; cursor:pointer; color:rgba(255,255,255,0.7); font-size:20px; line-height:1; padding:0;">✕</button>
    </header>

    <!-- Body -->
    <form id="checkpoint-form" style="padding:24px;">
      <input type="hidden" name="id" id="cp-id">

      <!-- Linha 1: Horário + Responsável -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.5px;">Horário</label>
          <div id="cp-created_at" style="font-size:14px; font-weight:700; color:#0f0069;">—</div>
        </div>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label style="font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.5px;">Responsável</label>
          <div id="cp-admin_name" style="font-size:14px; font-weight:700; color:#0f0069;">—</div>
        </div>
      </div>

      <!-- Linha 2: Atleta -->
      <div style="display:flex; flex-direction:column; gap:6px; margin-bottom:20px;">
        <label style="font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.5px;">Atleta</label>
        <div id="cp-runner_name" style="font-size:14px; font-weight:700; color:#0f0069;">—</div>
      </div>

      <!-- Divisor -->
      <div style="height:1px; background:#dadada; margin-bottom:20px;"></div>

      <!-- Linha 3: Distância + Pace -->
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom:16px;">
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label for="cp-distance" style="font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.5px;">Distância (km)</label>
          <input id="cp-distance" name="distance_km" type="number" step="0.1" placeholder="0.0"
                 style="border:1.5px solid #dadada; border-radius:10px; padding:10px 14px; font-family:'Montserrat',sans-serif; font-size:14px; font-weight:700; color:#0f0069; outline:none;">
        </div>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <label for="cp-pace" style="font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.5px;">Pace</label>
          <input id="cp-pace" name="pace" type="text" placeholder="5'00''/km"
                 style="border:1.5px solid #dadada; border-radius:10px; padding:10px 14px; font-family:'Montserrat',sans-serif; font-size:14px; font-weight:700; color:#0f0069; outline:none;">
        </div>
      </div>

      <!-- Linha 4: Tempo -->
      <div style="display:flex; flex-direction:column; gap:6px; margin-bottom:24px;">
        <label for="cp-time" style="font-size:11px; font-weight:700; color:#999; text-transform:uppercase; letter-spacing:.5px;">Tempo</label>
        <input id="cp-time" name="time" type="text" placeholder="00:00:00"
               style="border:1.5px solid #dadada; border-radius:10px; padding:10px 14px; font-family:'Montserrat',sans-serif; font-size:14px; font-weight:700; color:#0f0069; outline:none;">
      </div>

      <!-- Footer -->
      <div style="display:flex; gap:12px; justify-content:flex-end;">
        <button type="button" id="modal-cancel"
                style="padding:10px 22px; border:2px solid #dadada; border-radius:24px; background:transparent; font-family:'Montserrat',sans-serif; font-size:13px; font-weight:700; color:#999; cursor:pointer;">
          Cancelar
        </button>
        <button type="submit"
                style="padding:10px 28px; border:none; border-radius:24px; background:#d2003c; font-family:'Montserrat',sans-serif; font-size:13px; font-weight:700; color:#fff; cursor:pointer;">
          Salvar
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  // Serializa checkpoints para o escopo global antes de carregar o JS estático
  window.CHECKPOINTS = <%- JSON.stringify(checkpoints) %> || [];
</script>
<script src="/js/app.js"></script>