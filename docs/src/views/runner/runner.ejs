<%#
  VIEW: runner/runner.ejs
  ROTA: GET /public/team/:uuid  — painel PÚBLICO da equipe, acesso via link único (UUID), sem login (RN13)
  ESTADO: [C2 — Parcial]
  LACUNAS:
    - "Velocidade máx." computada a partir do pace mais rápido nos checkpoints [D2 — inferido, sem campo direto no model]
    - "Próximo atleta" = primeiro runner sem checkpoint registrado na competição [D2 — sem endpoint de scheduling na Seção 7]
    - "Calculadora de descanso": 120 min (2h) default — RN08 exige parâmetros do evento não expostos via API [D3 — não implementável sem novo endpoint]
    - Percentual de descanso computado por tempo decorrido desde último checkpoint, não por fórmula oficial [D2]
    - "Posição durante à competição" (gráfico) — histórico temporal de ranking não disponível na Seção 7 [D3 — placeholder]
    - "Tempo de competição" agora usa competition.started_at (marco real da ativação) ao invés de competition.date meia-noite [Implementado]
    - Ao encerrar a competição (closed), o cronômetro mostra "00:00:00" [Implementado]
  DECISÕES VALIDADAS (humano):
    - RN13: exibir dados individuais por atleta (pace/velocidade/distância) foi APROVADO seguindo o Figma Equipes.png — não simplificar o leaderboard nesta tela.
  ENDPOINTS CONSUMIDOS (via SSR):
    - teamService.findByUuid(uuid)                 [A1][B1] — resolve a equipe pelo link único
    - competitionService.findById(id)             [A1][B1]
    - runnerService.findByTeam(teamId)             [A1][B1]
    - rankingService.generateTeamRanking(id)       [A1][B1]
    - rankingService.generateRunnerRanking(id)     [A1][B1]
    - checkpointService.findByCompetition(id)      [A1][B1]
  ÚLTIMA ATUALIZAÇÃO: Sprint atual — corrida implementada em runnerController.ts:40 (computeElapsedTime usa started_at + status)
%>

<main class="runner-main">

  <%# ── Header ──────────────────────────────────────────────── %>
  <header class="runner-header">
    <div>
      <h1 class="runner-title"><%= team.name %></h1>
      <p class="runner-subtitle">
        <% if (teamStats.position > 0) { %>
          <%= teamStats.position %>º no ranking global
        <% } else { %>
          Ranking global
        <% } %>
      </p>
      <p class="runner-competition-time"><%= competitionTimeFormatted %></p>
    </div>

    <div class="runner-header-actions">


      <%# Botão compartilhar — [A1] copia URL pública /public/team/:uuid/ranking para clipboard %>
        <button
          id="btn-share"
          class="btn-share"
          data-share-uuid="<%= team.uuid %>"
          aria-label="Compartilhar link da equipe"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
               stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round"
                  d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
            </svg>
          </button>
        <!-- Link para acessar a tela de geração de posts (todos os tipos) -->


    </div>
  </header>

  <%# ── Cards de métricas ───────────────────────────────────── %>
  <section class="runner-metrics" aria-label="Métricas da equipe">

    <div class="metric-card">
      <p class="metric-label">Total da equipe</p>
      <p class="metric-value"><%= teamStats.total_distance_km.toFixed(1).replace('.', ',') %> km</p>
    </div>

    <div class="metric-card">
      <p class="metric-label">Distância para o <%= teamStats.is_leader ? 'segundo colocado' : 'líder' %></p>
      <% if (teamStats.is_leader && teamStats.distance_to_next_km > 0) { %>
        <p class="metric-value">+ <%= teamStats.distance_to_next_km.toFixed(2) %> km</p>
      <% } else if (teamStats.is_leader) { %>
        <p class="metric-value">Líder</p>
      <% } else { %>
        <p class="metric-value">+ <%= teamStats.distance_to_leader_km.toFixed(2) %> km</p>
      <% } %>
    </div>

    <div class="metric-card">
      <p class="metric-label">Pace médio da equipe</p>
      <% if (teamStats.average_pace) { %>
        <%
          var paceParts = teamStats.average_pace.split(':');
          var paceMin = paceParts[0];
          var paceSec = paceParts.length > 1 ? paceParts[1] : '00';
        %>
        <p class="metric-value"><%= paceMin %>'<%= paceSec %>''/km</p>
      <% } else { %>
        <p class="metric-value">—</p>
      <% } %>
    </div>

  </section>

  <%# ── Tabela de atletas ───────────────────────────────────── %>
  <section class="athletes-section">
    <h2 class="section-title">Status por atleta da equipe</h2>

    <% if (runnersEnriched.length === 0) { %>
      <div class="empty-state">Nenhum atleta cadastrado nesta equipe.</div>
    <% } else { %>
      <div class="table-wrapper">
        <table class="athletes-table">
          <thead>
            <tr>
              <th>Atleta</th>
              <th>Pace médio geral</th>
              <%# [D2] Velocidade máx. inferida do pace mais rápido registrado %>
              <th>Velocidade máx.</th>
              <th>Distância</th>
              <th>Último Checkpoint</th>
            </tr>
          </thead>
          <tbody>
            <% runnersEnriched.forEach(function(runner) { %>
              <tr>
                <td><%= runner.name %></td>
                <td>
                  <% if (runner.average_pace) { %>
                    <%= runner.average_pace %> min/km
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td>
                  <% if (runner.max_speed_kmh !== null) { %>
                    <%= runner.max_speed_kmh %> km/h
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td>
                  <% if (runner.total_distance_km > 0) { %>
                    <%= runner.total_distance_km.toFixed(1) %> km
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td><%= runner.last_checkpoint_at %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <%# ── Calculadora de descanso + Gráfico ─────────────────── %>
  <section class="bottom-section">

    <%# Calculadora de descanso %>
    <div class="rest-calculator">
      <h2 class="section-title">Calculadora de descanso</h2>

      <div class="rest-content">

        <% if (runnerRestOptions && runnerRestOptions.length > 0) { %>
          <label class="rest-runner-select">
            <span>Atleta</span>
            <select data-rest-runner-select>
              <% runnerRestOptions.forEach(function(option) { %>
                <option
                  value="<%= option.id %>"
                  <%= selectedRunnerRest && selectedRunnerRest.id === option.id ? 'selected' : '' %>
                >
                  <%= option.name %>
                </option>
              <% }); %>
            </select>
          </label>
        <% } %>

        <%# [D2] Percentual: tempo decorrido desde último checkpoint / 120 min recomendados %>
        <div class="circle-wrapper" aria-label="<%= restPct %>% do tempo de descanso concluído" data-rest-circle-label>
          <svg class="circle-svg" viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="50" fill="none"
                    stroke="var(--bordas-separadores)" stroke-width="12"/>
            <circle cx="60" cy="60" r="50" fill="none"
                    data-rest-circle-progress
                    stroke="<%= restPct >= 100 ? 'var(--verde)' : 'var(--amarelo)' %>"
                    stroke-width="12"
                    stroke-linecap="round"
                    stroke-dasharray="314.16"
                    stroke-dashoffset="<%= restOffset %>"
                    transform="rotate(-90 60 60)"/>
          </svg>
          <span class="circle-text" data-rest-percent><%= restPct %>%</span>
        </div>

        <div class="rest-info">

          <% if (restPct >= 100) { %>
            <div class="rest-status-badge ready" data-rest-status>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none"
                   viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
              <span data-rest-status-text><%= selectedRunnerRest ? selectedRunnerRest.statusLabel : 'Pronto para Voltar!' %></span>
            </div>
            <p class="rest-desc" data-rest-description><%= selectedRunnerRest ? selectedRunnerRest.description : 'Tempo de descanso atingido...' %></p>
          <% } else { %>
            <div class="rest-status-badge resting" data-rest-status>
              <span data-rest-status-text><%= selectedRunnerRest ? selectedRunnerRest.statusLabel : 'Em descanso' %></span>
            </div>
            <p class="rest-desc" data-rest-description><%= selectedRunnerRest ? selectedRunnerRest.description : 'Aguardando tempo de descanso...' %></p>
          <% } %>

          <%#
            [D3 ⚠ NÃO IMPLEMENTADO — aguardando confirmação]
            Valor de 120 min hardcoded — RN08 exige parâmetros do evento (não expostos na Seção 7).
            Implementar quando endpoint de parâmetros do evento for disponibilizado.
          %>
          <div class="rest-recommended">
            Tempo recomendado de descanso: <strong>120 min (2h)</strong>
          </div>

          <p class="rest-last-checkpoint" data-rest-last-checkpoint>
            Último checkpoint:
            <strong><%= selectedRunnerRest && selectedRunnerRest.hasCheckpoint ? selectedRunnerRest.lastCheckpointAt : '—' %></strong>
          </p>

          <%#
            [D2] Próximo atleta: runner sem checkpoint registrado nesta competição.
            Sem endpoint de scheduling na Seção 7 — inferido por ausência de registros.
          %>
          <p class="rest-next">
            Próximo atleta:
            <% if (nextRunner) { %>
              <strong><%= nextRunner.name %></strong>
            <% } else { %>
              <strong>—</strong>
            <% } %>
          </p>

        </div>
      </div>
    </div>

  </section>

</main>

<%# Toast feedback do botão compartilhar %>
<div id="share-toast" class="share-toast hidden" role="status" aria-live="polite">
  Link copiado!
</div>

<script>
  window.RUNNER_REST_OPTIONS = <%- JSON.stringify(runnerRestOptions || []) %>;
  setTimeout(function(){ location.reload(); }, <%= refreshDelayMs %>);
</script>
