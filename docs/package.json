  "description": "<p align=\"center\"> <a href= \"https://www.inteli.edu.br/\"><img src=\"/assets/inteli.png\" alt=\"Inteli - Instituto de Tecnologia e Liderança\" border=\"0\"></a> </p>",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc && copyfiles -u 1 src/views/*/ dist/views",
    "start": "node dist/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --coverage=false --testMatch \"**/tests/**/*.e2e.spec.ts\"",
    "test:unit": "jest --coverage=false --testMatch \"**/tests/**/*Service.@(test|spec).ts\"",
    "test:integration": "jest --coverage=false --testMatch \"**/tests/**/*Repository.spec.ts\""
  },
  "repository": {
    "type": "git",
    "url": "https://git.inteli.edu.br/graduacao/2026-1b/t27/g01.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "openai": "^6.42.0",
    "sharp": "^0.35.2",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
